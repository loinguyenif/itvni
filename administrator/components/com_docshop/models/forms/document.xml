<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="document">
        <field
            name="id"
            type="hidden"
        />
        <field
            name="title"
            type="text"
            label="COM_DOCSHOP_FIELD_TITLE_LABEL"
            description="COM_DOCSHOP_FIELD_TITLE_DESC"
            required="true"
            size="40"
        />
        <field
            name="alias"
            type="text"
            label="JFIELD_ALIAS_LABEL"
            description="JFIELD_ALIAS_DESC"
            size="40"
        />
        <field
            name="description"
            type="textarea"
            label="COM_DOCSHOP_FIELD_DESCRIPTION_LABEL"
            description="COM_DOCSHOP_FIELD_DESCRIPTION_DESC"
            rows="5"
            cols="40"
        />
        <field
            name="youtube_url"
            type="url"
            label="COM_DOCSHOP_FIELD_YOUTUBE_URL_LABEL"
            description="COM_DOCSHOP_FIELD_YOUTUBE_URL_DESC"
            size="40"
            filter="url"
        />
        <field
            name="price"
            type="number"
            label="COM_DOCSHOP_FIELD_PRICE_LABEL"
            description="COM_DOCSHOP_FIELD_PRICE_DESC"
            step="0.01"
            min="0"
        />
        <field
            name="category_id"
            type="sql"
            label="COM_DOCSHOP_FIELD_CATEGORY_LABEL"
            description="COM_DOCSHOP_FIELD_CATEGORY_DESC"
            query="SELECT id AS value, title AS text FROM #__docshop_categories WHERE published = 1 ORDER BY title ASC"
            key_field="value"
            value_field="text"
            header="COM_DOCSHOP_SELECT_CATEGORY"
        />
        <field
            name="file"
            type="file"
            label="COM_DOCSHOP_FIELD_FILE_LABEL"
            description="COM_DOCSHOP_FIELD_FILE_DESC"
            accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip"
        />
        <field
            name="published"
            type="list"
            label="JSTATUS"
            description="JFIELD_PUBLISHED_DESC"
            class="chzn-color-state"
            filter="intval"
            size="1"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field
            name="access"
            type="accesslevel"
            label="JFIELD_ACCESS_LABEL"
            description="JFIELD_ACCESS_DESC"
            default="1"
        />
        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
            description="JFIELD_ORDERING_DESC"
            content_type="com_docshop.document"
        />
        <field
            name="created"
            type="calendar"
            label="JGLOBAL_FIELD_CREATED_LABEL"
            description="JGLOBAL_FIELD_CREATED_DESC"
            format="%Y-%m-%d %H:%M:%S"
            filter="user_utc"
            translateformat="true"
            showtime="true"
            readonly="true"
        />
        <field
            name="created_by"
            type="user"
            label="JGLOBAL_FIELD_CREATED_BY_LABEL"
            description="JGLOBAL_FIELD_CREATED_BY_DESC"
            readonly="true"
        />
        <field
            name="modified"
            type="calendar"
            label="JGLOBAL_FIELD_MODIFIED_LABEL"
            description="JGLOBAL_FIELD_MODIFIED_DESC"
            format="%Y-%m-%d %H:%M:%S"
            filter="user_utc"
            translateformat="true"
            showtime="true"
            readonly="true"
        />
        <field
            name="modified_by"
            type="user"
            label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
            description="JGLOBAL_FIELD_MODIFIED_BY_DESC"
            readonly="true"
        />
    </fieldset>
</form>
