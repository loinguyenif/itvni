<?xml version="1.0" encoding="utf-8"?>


<form>

	<fieldset name="package.form" addfieldpath="/administrator/components/com_reminder/models/fields">

		<field name="name"
				alias="name"
				label="REMINDER_FIELD_NAME"
				filter="STRING"
				type="cktext"/>

		<field name="price"
				alias="price"
				label="REMINDER_FIELD_PRICE"
				filter="FLOAT"
				numericFormat="10,2"
				type="cktext"/>

		<field name="disk"
				alias="disk"
				label="REMINDER_FIELD_DISK"
				filter="STRING"
				type="cktext"/>

		<field name="param"
				alias="param"
				label="REMINDER_FIELD_PARAM"
				filter="STRING"
				type="cktextarea"/>

		<field name="published"
				alias="published"
				label="REMINDER_FIELD_PUBLISHED"
				filter="INT"
				access="core.edit.state"
				listKey="value"
				default="0"
				type="ckstate">
			<option value="0" icon="icomoon-cancel" color="danger">REMINDER_FIELDS_BOOL_NO</option>
			<option value="1" icon="icomoon-ok" color="success">REMINDER_FIELDS_BOOL_YES</option>
		</field>
	</fieldset>

	<fieldset name="default.filters" addfieldpath="/administrator/components/com_reminder/models/fields">

		<field name="filter_type"
				listKey="value"
				labelKey="text"
				type="enum"
				submit="true"
				nullLabel="REMINDER_FILTER_NULL_TYPE"
				enum="packages_type"
				label="REMINDER_JSEARCH_TYPE"
				class="element-filter"
				ui="chosen"/>

		<field name="search_search"
				type="cksearch"
				placeholder="REMINDER_FILTER_NULL_NAME_DISK"
				label="REMINDER_JSEARCH_NAME_DISK"
				class="element-filter element-search search-query"
				ui="chosen"/>

		<field name="sortTable"
				type="cksort"
				responsive="hidden-phone"
				submit="true"
				nullLabel="JGLOBAL_SORT_BY"
				class="span-2 element-filter"
				label="Sort by"
				ui="chosen"/>

		<field name="directionTable"
				type="ckdirection"
				responsive="hidden-phone"
				submit="true"
				nullLabel="JFIELD_ORDERING_DESC"
				class="span-2 element-filter"
				label="Direction"
				ui="chosen"/>

		<field name="limit"
				type="cklimit"
				submit="true"
				class="element-filter"
				label="Limit"
				ui="chosen"/>
	</fieldset>

	<fieldset name="modal.filters" addfieldpath="/administrator/components/com_reminder/models/fields">

		<field name="limit"
				type="cklimit"
				submit="true"
				class="element-filter"
				label="Limit"
				ui="chosen"/>
	</fieldset>
</form>